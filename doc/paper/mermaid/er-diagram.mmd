erDiagram
    %% Neo4j多标签架构E-R图
    %% 使用 :label 表示标签，复合标签如 :item:block 在注释中说明
    
    ITEM {
        int ID PK
        string Name
        int Type
        string Disc
        string GetWay
    }
    
    BLOCK {
        int ID PK
        int MineTool
        int ToolLevel
    }
    
    MONSTER {
        int ID PK
        int Life
        int Attack
    }
    
    GROUP {
        int ID PK
    }
    
    RECIPE {
        int ID PK
        int IsFollowMe
        string StationLabel
    }
    
    SMELT {
        int ID PK
        int Type
    }
    
    DEVICE {
        string type PK
    }
    
    %% 多标签说明：方块节点同时具有 :item 和 :block 标签
    ITEM ||--|| BLOCK : "继承为复合标签\n:item:block"
    
    %% 多标签说明：生物节点同时具有 :item 和 :monster 标签
    ITEM ||--|| MONSTER : "继承为复合标签\n:item:monster"
    
    %% 普通关系
    ITEM }|--|| GROUP : "IN_GROUP"
    
    RECIPE }|--|{ ITEM : "CONSUMES"
    RECIPE }|--|{ BLOCK : "CONSUMES"
    RECIPE }|--|{ GROUP : "CONSUMES"
    
    RECIPE ||--|{ ITEM : "PRODUCES"
    RECIPE ||--|{ BLOCK : "PRODUCES"
    
    RECIPE ||--o{ ITEM : "CONTAIN"
    
    %% 方块相关关系（:item:block 节点）
    BLOCK }|--|{ ITEM : "HANDMINEDROPS"
    BLOCK }|--|{ ITEM : "TOOLMINEDROPS"
    BLOCK ||--o| ITEM : "PreciseDrop"
    
    %% 生物相关关系（:item:monster 节点）
    MONSTER }|--|{ ITEM : "DROPS"
    
    %% 设备相关关系
    DEVICE ||--o| GROUP : "COVERS"
    DEVICE ||--o| BLOCK : "COVERS"
    
    SMELT }|--|| DEVICE : "RUNS_ON"
    SMELT }|--|{ ITEM : "CONSUMES"
    SMELT ||--|{ ITEM : "PRODUCES"
    
    ITEM }|--|| DEVICE : "FUEL_FOR"
    ITEM }|--|| DEVICE : "OXYGEN_SOURCE"
