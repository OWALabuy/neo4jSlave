graph TB
    subgraph 输入["输入: Neo4j 查询结果"]
        R1[Record 1]
        R2[Record 2]
        Rn[...]
    end

    subgraph 处理["处理: 数据提取"]
        E1[遍历记录]
        E2[识别节点]
        E3[识别关系]
        E4[去重处理]
    end

    subgraph 输出["输出: ECharts 格式"]
        N[nodes: 节点数组]
        L[links: 关系数组]
        C[categories: 类别数组]
    end

    R1 --> E1
    R2 --> E1
    Rn --> E1
    E1 --> E2
    E1 --> E3
    E2 --> E4
    E3 --> E4
    E4 --> N
    E4 --> L
    E4 --> C

    style 输入 fill:#e1f5ff
    style 处理 fill:#ffffe1
    style 输出 fill:#e1ffe1
